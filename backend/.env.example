# ─────────────────────────────────────────────────────────────
# Document AI Hub — Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────

# Google Gemini API Key (required)
# Get yours at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Roboflow API Key (required for Aadhaar / PAN verifier modules)
# Get yours at: https://app.roboflow.com/settings/api
ROBOFLOW_API_KEY=your_roboflow_api_key_here

# Express Session Secret (required — use a long random string)
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=replace_this_with_a_very_long_random_string

# Optional: Python ML microservice URL
# Leave empty to use cloud APIs only
ML_SERVICE_URL=

# Server configuration
NODE_ENV=development
PORT=3000
